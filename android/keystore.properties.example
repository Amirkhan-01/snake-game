# Release signing config — TEMPLATE.
# Copy this file to  android/keystore.properties  (that copy is gitignored) and
# fill in your real values. Keep the keystore file AND these passwords safe:
# if you lose them you can NEVER update the app on Google Play again.
#
# 1) Create the keystore once (place it in android/app/ so *.jks is gitignored):
#      cd android/app
#      keytool -genkey -v -keystore snake-release.jks -keyalg RSA -keysize 2048 \
#              -validity 10000 -alias snake
#
# 2) Fill the values below (storeFile is relative to android/app/).
# 3) Build a signed bundle:  cd android && ./gradlew bundleRelease
#      -> android/app/build/outputs/bundle/release/app-release.aab

storeFile=snake-release.jks
storePassword=CHANGE_ME
keyAlias=snake
keyPassword=CHANGE_ME
