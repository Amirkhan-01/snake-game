{
  "name": "snake-premium",
  "version": "1.0.0",
  "private": true,
  "description": "Snake — Premium Edition (mobile wrapper via Capacitor)",
  "scripts": {
    "sync": "npm run build:native && cap sync",
    "open:android": "cap open android",
    "build:native": "esbuild src/native.js --bundle --format=iife --outfile=web/native.js --minify"
  },
  "dependencies": {
    "@capacitor-community/admob": "^8.0.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@revenuecat/purchases-capacitor": "^13.2.2"
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}